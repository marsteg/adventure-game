# Image Generation Provider Configuration
# API keys are now in .env file (copy .env.example to .env and add your keys)

# Provider: 'huggingface' (FREE unlimited) or 'stability' (limited)
provider: "huggingface"

# === HUGGING FACE ===
# Set HF_TOKEN in .env file
# Get FREE token at: https://huggingface.co/settings/tokens (no credit card!)
huggingface_model: "black-forest-labs/FLUX.1-schnell"

# === STABILITY AI ===
# Set STABILITY_API_KEY in .env file (if using stability provider)
# Get key at: https://platform.stability.ai/
# Warning: Only ~3 images/month on free tier

# Image dimensions per asset type [width, height]
# These are defaults - can be overridden per-call with --width and --height
# In interactive mode, you'll be prompted for size (press Enter for default)
dimensions:
  npc: [1024, 1024]      # Square for characters
  item: [1024, 1024]     # Square for items
  door: [512, 768]       # Portrait for doors
  room: [1024, 1024]     # Square (or try [1920, 1080] for widescreen)

# Background removal per asset type
remove_background:
  npc: true              # Remove background for NPCs (transparent)
  item: true             # Remove background for items (transparent)
  door: false            # Keep background for doors
  room: false            # Keep background for rooms

# Audio Generation Provider Configuration
# Supported providers:
#   - speecht5: Microsoft SpeechT5 (pip install, ~500MB, CPU-friendly, good quality)
#   - xtts: Coqui XTTS-v2 (pip install TTS, ~2GB, GPU recommended, excellent quality, voice cloning)
#   - kugelaudio: KugelAudio (git clone required, ~13GB, GPU only, highest quality)
audio_provider: "speecht5"

# Audio settings per provider
audio_settings:
  # SpeechT5 settings (microsoft/speecht5_tts)
  speecht5:
    model: "microsoft/speecht5_tts"
    vocoder: "microsoft/speecht5_hifigan"
    speaker_embeddings: "Slt"  # Default speaker voice
    sample_rate: 16000

  # XTTS-v2 settings (Coqui TTS)
  xtts:
    model: "tts_models/multilingual/multi-dataset/xtts_v2"
    language: "en"
    sample_rate: 24000
    temperature: 0.7
    length_penalty: 1.0
    repetition_penalty: 5.0
    speaker_wav: null  # Optional: path to reference voice sample for cloning

  # KugelAudio settings (requires git clone)
  kugelaudio:
    voice: "default"
    cfg_scale: 3.0
    max_new_tokens: 2048
    sample_rate: 24000
