# Example Image Generation Provider Configuration
# Supported providers:
#   - huggingface: Hugging Face Inference API (free, fast, unlimited)
#   - stability: Stability AI API (paid, limited free tier)
#   - local: Run models locally on your GPU/CPU (free, unlimited, private)
provider: "local"

# Image settings per provider
image_settings:
  # Hugging Face API settings
  huggingface:
    model: "black-forest-labs/FLUX.1-schnell"

  # Stability AI API settings
  stability:
    model: "sd3"  # sd3 or sdxl

  # Local model settings (requires: pip install diffusers transformers accelerate torch)
  local:
    # Active model - change this to switch between models
    # Options: "flux", "sdxl", "kandinsky"
    active_model: "flux"

    # Model-specific configurations
    models:
      flux:
        model_id: "black-forest-labs/FLUX.1-schnell"
        num_inference_steps: 4 # 4 is the recommended setting
        guidance_scale: 0.0 # 0.0 is the recommended setting
        description: "Fast generation (4 steps), works on Apple Silicon with bfloat16."

      sdxl:
        model_id: "stabilityai/stable-diffusion-xl-base-1.0"
        num_inference_steps: 25          # 25-30 steps recommended for best quality (lower is faster but less detailed)
        guidance_scale: 7.5          # 7.5 is a good default for strong adherence to prompt (lower = more creative, higher = more literal)
        description: "High quality, uses float32 on Apple Silicon"

      kandinsky:
        model_id: "kandinsky-community/kandinsky-2-2-decoder"
        num_inference_steps: 25  # 25-30 steps recommended for best quality (lower is faster but less detailed)
        guidance_scale: 7.5 # 7.5 is a good default for Kandinsky (lower = more creative, higher = more literal)
        description: "Artistic style, good balance of speed and quality"

    # Refiner model for Double-Asset feature (img2img refinement)
    # Set to null to disable refinement (uses base model for both)
    refiner_model: "stabilityai/stable-diffusion-xl-refiner-1.0"
    refiner_steps: 20           # Refinement steps (15-25 recommended)
    refiner_strength: 0.3       # How much to change (0.2-0.4 recommended, lower=more consistent)

    # Device: "auto" (recommended), "cuda", "mps", or "cpu"
    device: "auto"

    # Memory optimization (enable for <12GB VRAM)
    enable_model_cpu_offload: false   # Offload to CPU when idle (don't use with FLUX on MPS)
    enable_vae_slicing: true          # Reduce VRAM usage
    enable_attention_slicing: true    # Further VRAM reduction

    # Cache settings
    cache_dir: "~/.cache/huggingface"
    use_safetensors: true

# Image dimensions per asset type
dimensions:
  npc: [1024, 1024]      # for characters
  item: [1024, 1024]     # for items
  door: [1024, 1024]     # for doors
  room: [1920, 1080]     # for rooms (widescreen backgrounds)
  action: [1024, 1024]     # for action icons/cursors (smaller size)

# default Background removal per asset type
remove_background:
  npc: true              # Remove background for NPCs
  item: true             # Remove background for items
  door: true             # Remove background for doors
  room: false            # Keep background for rooms
  action: true           # Remove background for actions

# Audio Generation Provider Configuration
# Supported providers:
#   - speecht5: Microsoft SpeechT5 (pip install, ~500MB, CPU-friendly, good quality)
#   - xtts: Coqui XTTS-v2 (pip install TTS, ~2GB, GPU recommended, excellent quality, voice cloning)
#   - kugelaudio: KugelAudio (git clone required, ~13GB, GPU only, highest quality)
audio_provider: "speecht5"

# Audio settings per provider
audio_settings:
  # SpeechT5 settings (microsoft/speecht5_tts)
  speecht5:
    model: "microsoft/speecht5_tts"
    vocoder: "microsoft/speecht5_hifigan"
    speaker_embeddings: "Slt"  # Default speaker voice
    sample_rate: 16000

  # XTTS-v2 settings (Coqui TTS)
  xtts:
    model: "tts_models/multilingual/multi-dataset/xtts_v2"
    language: "en"
    sample_rate: 24000
    temperature: 0.7
    length_penalty: 1.0
    repetition_penalty: 5.0
    speaker_wav: null  # Optional: path to reference voice sample for cloning

  # KugelAudio settings (requires git clone)
  kugelaudio:
    voice: "default"
    cfg_scale: 3.0
    max_new_tokens: 2048
    sample_rate: 24000
